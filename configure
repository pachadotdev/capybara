# Anticonf script by Pacha (2025)

PKG_CONFIG_NAME="capybara"

# This is to adhere to CRAN policy about not forcing -O3 and other optimizations
ENABLE_OPTIMIZATION=no
for arg in "$@"; do
  echo "Processing argument: $arg"
  case "$arg" in
    --enable-optimization)
      ENABLE_OPTIMIZATION=yes
      echo "Optimization enabled!"
      ;;
  esac
done

# Find compiler
CXX=$(${R_HOME}/bin/R CMD config CXX)
CXXFLAGS=$(${R_HOME}/bin/R CMD config CXXFLAGS)
CPPFLAGS=$(${R_HOME}/bin/R CMD config CPPFLAGS)

# Get R's default pic flags (contains optimization)
CXXPICFLAGS=$(${R_HOME}/bin/R CMD config CXXPICFLAGS)
echo "Default CXXPICFLAGS: $CXXPICFLAGS"

# Set optimization flags if requested
OPTFLAGS=""
OVERRIDE_CXXPICFLAGS=""
if [ "$ENABLE_OPTIMIZATION" = "yes" ]; then
  echo "Setting up optimization flags..."
  
  # Test for -O3 support
  echo 'int main(){return 0;}' > conftest.cpp
  if $CXX -O3 conftest.cpp -o conftest >/dev/null 2>&1; then 
    OPTFLAGS="-O3"
    echo "Compiler supports -O3"
  else
    echo "Warning: compiler does not support -O3, falling back to -O2"
    OPTFLAGS="-O2"
  fi
  rm -f conftest conftest.cpp

  # Add the rest of optimization flags
  OPTFLAGS="$OPTFLAGS -funroll-loops -march=native"
  
  # Check for AVX2 support
  if grep -q avx2 /proc/cpuinfo 2>/dev/null || sysctl -n machdep.cpu.features 2>/dev/null | grep -q AVX2; then
    OPTFLAGS="$OPTFLAGS -mavx2"
  fi

  # Create override for CXXPICFLAGS (removes default -O2 and adds our flags)
  OVERRIDE_CXXPICFLAGS=$(echo "$CXXPICFLAGS" | sed -E 's/-O[0-9s]//g')
  OVERRIDE_CXXPICFLAGS="$OVERRIDE_CXXPICFLAGS $OPTFLAGS"

  echo "OPTFLAGS: $OPTFLAGS"
  echo "OVERRIDE_CXXPICFLAGS: $OVERRIDE_CXXPICFLAGS"
else
  # Use R's defaults
  OVERRIDE_CXXPICFLAGS="$CXXPICFLAGS"
  echo "Not using additional optimization flags"
  echo "OVERRIDE_CXXPICFLAGS: $OVERRIDE_CXXPICFLAGS"
fi

# Link BLAS/LAPACK against MKL if MKLROOT is set
R_BLAS_LIBS=$("${R_HOME}/bin/R" CMD config BLAS_LIBS)
R_LAPACK_LIBS=$("${R_HOME}/bin/R" CMD config LAPACK_LIBS)
R_FLIBS=$("${R_HOME}/bin/R" CMD config FLIBS)

: ${BLAS_LIBS:="$R_BLAS_LIBS"}
: ${LAPACK_LIBS:="$R_LAPACK_LIBS"}
: ${FLIBS:="$R_FLIBS"}

if [ -n "$MKLROOT" ]; then
  echo "detected MKLROOT=$MKLROOT → linking BLAS/LAPACK via MKL"
  BLAS_LIBS="-L${MKLROOT}/lib/intel64_lin -lmkl_rt"
  LAPACK_LIBS="$BLAS_LIBS"
fi

# Check for OpenMP support
OPENMP_FLAG=""
for flag in -fopenmp -qopenmp -openmp -xopenmp; do
  save_CXXFLAGS="$CXXFLAGS"
  CXXFLAGS="$CXXFLAGS $flag"
  
  echo "int main() { return 0; }" | $CXX -xc++ -E $CXXFLAGS - >/dev/null 2>&1
  if [ $? -eq 0 ]; then
    OPENMP_FLAG="$flag"
    break
  fi
  CXXFLAGS="$save_CXXFLAGS"
done

# Determine number of cores using OpenMP if available
if [ -n "$CAPYBARA_NCORES" ]; then
  num_cores="$CAPYBARA_NCORES"
  echo "using environment value: $num_cores"
else
  cat > nthreads.cpp << 'EOL'
#include <iostream>
#ifdef _OPENMP
  #include <omp.h>
#endif

int main() {
  int nthreads;
  #ifdef _OPENMP
    nthreads = std::max(1, omp_get_max_threads() - 1);
  #else
    nthreads = 1;
  #endif
  std::cout << nthreads << std::endl;
  return 0;
}
EOL

  # Need to compile WITH the OpenMP flag
  if [ -n "$OPENMP_FLAG" ]; then
    $CXX nthreads.cpp -o nthreads $OPENMP_FLAG
  else
    $CXX nthreads.cpp -o nthreads
  fi
  
  # Check if compilation succeeded
  if [ $? -eq 0 ] && [ -x ./nthreads ]; then
    num_cores=$(./nthreads)
    echo "Number of available cores: $num_cores"
  else
    echo "OpenMP test failed, defaulting to 1"
    num_cores=1
  fi

  # Clean up
  rm -f nthreads nthreads.cpp
fi

if [ "$ENABLE_OPTIMIZATION" = "yes" ]; then
  # Extract R's CXXFLAGS without optimization
  R_CXXFLAGS=$(${R_HOME}/bin/R CMD config CXXFLAGS | sed -E 's/-O[0-9s]//g')
  
  echo "# Override R's CXXFLAGS to remove default optimization" >> src/Makevars.tmp
  echo "CXXFLAGS = $R_CXXFLAGS" >> src/Makevars.tmp
  echo "" >> src/Makevars.tmp
  
  # Now append the rest of Makevars
  sed -e "s|@ncores@|${num_cores}|g" \
      -e "s|@OPTFLAGS@|${OPTFLAGS}|g" \
      -e "s|@OVERRIDE_CXXPICFLAGS@|${OVERRIDE_CXXPICFLAGS}|g" \
      -e "s|@PKG_CXXFLAGS@|${PKG_CXXFLAGS}|g" \
      -e "s|@PKG_LIBS@|${PKG_LIBS}|g" \
      src/Makevars.in >> src/Makevars.tmp
  
  mv src/Makevars.tmp src/Makevars
else
  # Standard processing
  sed -e "s|@ncores@|${num_cores}|g" \
      -e "s|@OPTFLAGS@|${OPTFLAGS}|g" \
      -e "s|@OVERRIDE_CXXPICFLAGS@|${OVERRIDE_CXXPICFLAGS}|g" \
      -e "s|@PKG_CXXFLAGS@|${PKG_CXXFLAGS}|g" \
      -e "s|@PKG_LIBS@|${PKG_LIBS}|g" \
      src/Makevars.in > src/Makevars
fi

# Success
exit 0
