CXX_STD ?= CXX11 CXX14 CXX17

ARMA_FLAGS = -DARMA_NO_DEBUG \
  -DARMA_USE_BLAS \
  -DARMA_USE_LAPACK \
  -DARMA_OPENMP_THREADS=@ncores@

PKG_CXXFLAGS = $(ARMA_FLAGS) $(SHLIB_OPENMP_CXXFLAGS)
PKG_CXX11FLAGS = $(PKG_CXXFLAGS)
PKG_CXX14FLAGS = $(PKG_CXXFLAGS)
PKG_CXX17FLAGS = $(PKG_CXXFLAGS)

PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) \
  $(LAPACK_LIBS) \
  $(BLAS_LIBS) \
  $(FLIBS)

# List all your source files here
SOURCES = armadillo_functions.cpp cpp11.cpp

# Create object file list
OBJECTS = armadillo_functions.o cpp11.o

# Override all object file compilation with our custom rule
all: $(SHLIB)

$(SHLIB): $(OBJECTS)

# Custom compilation rule for each object file
# Note: Use -std=gnu++17 directly instead of $(CXX_STD)
armadillo_functions.o: armadillo_functions.cpp
	$(CXX) -std=gnu++17 $(ALL_CPPFLAGS) $(PKG_CXXFLAGS) -fpic @OPTFLAGS@ -c armadillo_functions.cpp -o armadillo_functions.o

cpp11.o: cpp11.cpp
	$(CXX) -std=gnu++17 $(ALL_CPPFLAGS) $(PKG_CXXFLAGS) -fpic @OPTFLAGS@ -c cpp11.cpp -o cpp11.o
